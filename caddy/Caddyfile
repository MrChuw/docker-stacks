import /shared/shared.caddy

{
  metrics {
    per_host
  }
  admin :2019
  log {
    output file /var/log/caddy/caddy_main.log {
      roll_size 500MiB
      roll_keep 10
      roll_keep_for 365d
    }
    format json
    level INFO
  }
}

